# ============================================
# Voice Scheduling Agent - Environment Variables
# ============================================

# Server Configuration
PORT=8000
BASE_URL=http://localhost:8000

# ============================================
# GOOGLE CALENDAR API CREDENTIALS
# ============================================
# 
# HOW TO GET THESE:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (or use existing)
# 3. Enable "Google Calendar API" in API Library
# 4. Go to Credentials → Create Credentials → OAuth 2.0 Client ID
# 5. Select "Web application"
# 6. Add redirect URI: http://localhost:8000/calendar/auth/google/callback
#    (For production, add your deployed URL too)
# 7. Copy Client ID and Client Secret below

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# REFRESH TOKEN - Get this after OAuth flow
# 1. Start server: python main.py
# 2. Visit: http://localhost:8000/calendar/auth/google
# 3. Authorize with your Google account
# 4. Copy the refresh_token from the response
# 5. Paste it here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# ============================================
# VAPI CONFIGURATION (Optional)
# ============================================
# Only needed if using Vapi's programmatic API
# For webhook-only integration, this is optional
# Get from: https://dashboard.vapi.ai → API Keys
VAPI_API_KEY=your_vapi_api_key_optional

# ============================================
# DEPLOYMENT URL (Update when deploying)
# ============================================
# For Render: https://your-app-name.onrender.com
# For Railway: https://your-app-name.railway.app
# PRODUCTION_URL=https://your-deployed-url.com
